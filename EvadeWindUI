-- ==============================================
getgenv().TicketESP = {
    Enabled = false,
    Billboards = {},
    Connections = {}
}

local function createTicketESP(ticket)
    if not ticket or not ticket:IsA("BasePart") then return end
    if ticket:FindFirstChild("TicketESP") then return end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "TicketESP"
    billboard.Adornee = ticket
    billboard.Size = UDim2.new(0, 100, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = ticket
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "🎫 TICKET"
    label.TextColor3 = Color3.fromRGB(255, 215, 0)
    label.TextStrokeTransparency = 0.3
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.Parent = billboard
    
    table.insert(getgenv().TicketESP.Billboards, billboard)
end

local function updateTicketESP()
    for _, billboard in ipairs(getgenv().TicketESP.Billboards) do
        pcall(function() billboard:Destroy() end)
    end
    getgenv().TicketESP.Billboards = {}
    
    if not getgenv().TicketESP.Enabled then return end
    
    local tickets = findTickets()
    for _, ticket in ipairs(tickets) do
        createTicketESP(ticket)
    end
end

