-- 6. AUTO TRIMP (FRONT JUMP) + FLOATING BUTTON
-- ==============================================
getgenv().FeatureStates = getgenv().FeatureStates or {}
getgenv().FeatureStates.FrontJumpEnabled = false
getgenv().FeatureStates.FrontJumpSpeed = 50
getgenv().frontJumpVelocity = nil

local function startFrontJump()
    if getgenv().frontJumpVelocity then getgenv().frontJumpVelocity:Destroy() end
    local char, root = player.Character, player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not char or not root then return end
    
    getgenv().frontJumpVelocity = Instance.new("BodyVelocity")
    getgenv().frontJumpVelocity.MaxForce = Vector3.new(400000, 0, 400000)
    getgenv().frontJumpVelocity.P = 1250
    getgenv().frontJumpVelocity.Parent = root

    task.spawn(function()
        while getgenv().FeatureStates.FrontJumpEnabled and getgenv().frontJumpVelocity and getgenv().frontJumpVelocity.Parent do
            local forward = Camera.CFrame.LookVector
            local direction = Vector3.new(forward.X, 0, forward.Z).Unit
            if direction.Magnitude < 0.1 then direction = root.CFrame.LookVector; direction = Vector3.new(direction.X, 0, direction.Z).Unit end
            getgenv().frontJumpVelocity.Velocity = direction * getgenv().FeatureStates.FrontJumpSpeed
            task.wait(0.016)
        end
    end)
end

local function toggleAutoTrimp()
    local new = not getgenv().FeatureStates.FrontJumpEnabled
    getgenv().FeatureStates.FrontJumpEnabled = new
    if new then startFrontJump() else
        if getgenv().frontJumpVelocity then getgenv().frontJumpVelocity:Destroy() getgenv().frontJumpVelocity = nil end
    end
    if AutoTrimpToggle then AutoTrimpToggle:Set(new) end
    WindUI:Notify({ Title = "AutoTrimp", Content = new and "ON" or "OFF", Duration = 1 })
end

