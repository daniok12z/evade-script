local function applyKorbloxR6(character)
    local rightLeg = character:FindFirstChild("Right Leg"); if not rightLeg then return end
    for _, child in ipairs(rightLeg:GetChildren()) do if child:IsA("SpecialMesh") or child:IsA("CharacterMesh") then child:Destroy() end end
    rightLeg.Color = DARK_GREY_COLOR
    table.insert(getgenv().HeadlessKorblox.Connections, rightLeg:GetPropertyChangedSignal("Color"):Connect(function() if rightLeg.Color ~= DARK_GREY_COLOR then rightLeg.Color = DARK_GREY_COLOR end end))
    local korbloxMesh = Instance.new("SpecialMesh")
    korbloxMesh.MeshType = Enum.MeshType.FileMesh; korbloxMesh.MeshId = KORBLOX_MESH_ID; korbloxMesh.TextureId = KORBLOX_TEXTURE_ID; korbloxMesh.Scale = Vector3.new(1, 1, 1); korbloxMesh.Parent = rightLeg
