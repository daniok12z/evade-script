local ConfigManager = Window.ConfigManager
local currentConfigName = "CasaaSettings"
local myConfig = ConfigManager:CreateConfig(currentConfigName)

local configElements = {
    AutoTrimp = AutoTrimpToggle,
    Bhop = BhopToggle,
    AutoCarry = AutoCarryToggle,
    DownedESP = DownedESPToggle,
    NoClip = NoClipToggle,
    AntiAFK = AntiAFKToggle,
    AutoTicketFarm = AutoTicketFarmToggle,
    AutoMoneyFarm = AutoMoneyFarmToggle,
    InfiniteSlide = InfiniteSlideToggle,
}

for flagName, element in pairs(configElements) do
    element.Flag = flagName
    myConfig:Register(flagName, element)
end

local function getConfigList()
    local configs = {}
    local success, result = pcall(function() return ConfigManager:AllConfigs() end)
    if success and result then for _, name in ipairs(result) do table.insert(configs, name) end end
    return configs
end

ConfigTab:Input({
    Title = "Config Name", Desc = "Nama file config", Placeholder = "CasaaSettings", Value = "CasaaSettings",
    Callback = function(value)
        if value and value ~= "" then
            currentConfigName = value:gsub("%s+", "")
            myConfig = ConfigManager:CreateConfig(currentConfigName)
            for flagName, element in pairs(configElements) do myConfig:Register(flagName, element) end
        end
    end
})

local ConfigDropdown = ConfigTab:Dropdown({
    Title = "Load Config", Values = getConfigList(),
    Callback = function(selected)
        if selected and selected ~= "" then
            currentConfigName = selected
            myConfig = ConfigManager:CreateConfig(currentConfigName)
            for flagName, element in pairs(configElements) do myConfig:Register(flagName, element) end
            WindUI:Notify({ Title = "Config", Content = "Selected: " .. selected, Duration = 2 })
        end
    end
})

ConfigTab:Button({ Title = "🔄 Refresh List", Callback = function()
    local configs = getConfigList()
    ConfigDropdown:SetValues(configs)
    WindUI:Notify({ Title = "Config", Content = #configs > 0 and ("Found " .. #configs .. " configs") or "No configs", Duration = 2 })
end })

ConfigTab:Button({ Title = "💾 Save Config", Callback = function()
    local success = pcall(function() myConfig:Save() end)
    if success then
        WindUI:Notify({ Title = "Config", Content = "Saved to: " .. currentConfigName, Duration = 2 })
        task.wait(0.5); ConfigDropdown:SetValues(getConfigList())
    else WindUI:Notify({ Title = "Error", Content = "Failed to save", Duration = 2, Icon = "alert-triangle" }) end
end })

ConfigTab:Button({ Title = "📂 Load Config", Callback = function()
    local success = pcall(function() myConfig:Load() end)
    if success then WindUI:Notify({ Title = "Config", Content = "Loaded: " .. currentConfigName, Duration = 2 })
    else WindUI:Notify({ Title = "Error", Content = "Failed to load", Duration = 2, Icon = "alert-triangle" }) end
end })

ConfigTab:Button({ Title = "🗑️ Delete Config", Callback = function()
    WindUI:Popup({
        Title = "Confirm Delete",
        Content = "Hapus " .. currentConfigName .. "?",
        Buttons = {
            { Title = "Yes", Callback = function()
                local success = pcall(function() myConfig:Delete() end)
                if success then
                    WindUI:Notify({ Title = "Config", Content = "Deleted: " .. currentConfigName, Duration = 2 })
                    currentConfigName = "CasaaSettings"
                    myConfig = ConfigManager:CreateConfig(currentConfigName)
                    for flagName, element in pairs(configElements) do myConfig:Register(flagName, element) end
                    ConfigDropdown:SetValues(getConfigList())
                else WindUI:Notify({ Title = "Error", Content = "Failed to delete", Duration = 2, Icon = "alert-triangle" }) end
            end },
            { Title = "No", Variant = "Tertiary" }
        }
    })
end })

