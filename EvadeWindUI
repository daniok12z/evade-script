-- 10. AUTO CARRY (TETEP)
-- ==============================================
getgenv().autoCarryEnabled = false
getgenv().autoCarryConnection = nil

local function startAutoCarry()
    if getgenv().autoCarryConnection then return end
    getgenv().autoCarryConnection = RunService.Heartbeat:Connect(function()
        if not getgenv().autoCarryEnabled then return end
        local char, hrp = player.Character, player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (hrp.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                if dist <= 20 then
                    pcall(function() ReplicatedStorage.Events.Character.Interact:FireServer("Carry", nil, plr.Name) end)
                    task.wait(0.05)
                end
            end
        end
    end)
end

local function stopAutoCarry()
    if getgenv().autoCarryConnection then getgenv().autoCarryConnection:Disconnect() getgenv().autoCarryConnection = nil end
end

function toggleAutoCarry()
    local new = not getgenv().autoCarryEnabled
    getgenv().autoCarryEnabled = new
    if new then startAutoCarry() else stopAutoCarry() end
    if AutoCarryToggle then AutoCarryToggle:Set(new) end
    WindUI:Notify({ Title = "AutoCarry", Content = new and "ON" or "OFF", Duration = 1 })
    
    -- Update mobile button kalo ada
    if MobileUI.CarryButton then
        MobileUI.CarryButton.BackgroundColor3 = new and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    end
end

