-- 9. BHOP - FITUR TETEP ADA, KEYBIND KOSONG
-- ==============================================
getgenv().FeatureStates.BhopEnabled = false
getgenv().BhopConnection = nil

local function handleBhop()
    if not getgenv().FeatureStates.BhopEnabled then return end
    local char, humanoid, root = player.Character, player.Character and player.Character:FindFirstChildOfClass("Humanoid"), player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not char or not humanoid or not root then return end
    local ray = Ray.new(root.Position, Vector3.new(0, -4, 0))
    local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char})
    if hit and humanoid:GetState() ~= Enum.HumanoidStateType.Jumping then humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
end

local BhopToggle = AutoTab:Toggle({
    Title = "Bhop", 
    Desc = "Auto jump (keybind kosong)", 
    Value = false,
    Callback = function(state)
        getgenv().FeatureStates.BhopEnabled = state
        if state then
            if getgenv().BhopConnection then getgenv().BhopConnection:Disconnect() end
            getgenv().BhopConnection = RunService.Heartbeat:Connect(handleBhop)
            WindUI:Notify({ Title = "Bhop", Content = "ON - Isi keybind di tab Keybind", Duration = 1 })
        else
            if getgenv().BhopConnection then getgenv().BhopConnection:Disconnect() getgenv().BhopConnection = nil end
            WindUI:Notify({ Title = "Bhop", Content = "OFF", Duration = 1 })
        end
    end
})

