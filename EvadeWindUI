    local rightLowerLeg = character:FindFirstChild("RightLowerLeg"); local rightFoot = character:FindFirstChild("RightFoot")
    if rightLowerLeg then rightLowerLeg.Transparency = 1 end; if rightFoot then rightFoot.Transparency = 1 end
    local korbloxLeg = Instance.new("Part")
