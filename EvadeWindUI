end })

-- Accessory Loader
getgenv().AccessoryLoader = { Enabled = false, AccessoryId = "", Connections = {} }
local function applyAccessory(character, accessoryId)
    if not character or accessoryId == "" then return end
    for _, v in ipairs(character:GetChildren()) do if v:IsA("Accessory") and v.Name == "LoadedAccessory" then v:Destroy() end end
    local success, result = pcall(function()
        local accessory = Instance.new("Accessory"); accessory.Name = "LoadedAccessory"; accessory.AccessoryType = Enum.AccessoryType.Unknown; accessory.Parent = character
        local handle = Instance.new("Part"); handle.Name = "Handle"; handle.Parent = accessory
        local mesh = Instance.new("SpecialMesh"); mesh.MeshId = accessoryId; mesh.Parent = handle
        return accessory
    end)
    if success then local humanoid = character:FindFirstChildOfClass("Humanoid"); if humanoid then humanoid:AddAccessory(result) end end
end
