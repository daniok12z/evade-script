-- 12. AUTO TICKET FARM
-- ==============================================
getgenv().TicketSystem = {
    AutoTicketFarm = false,
    Collected = 0,
    AutoConnection = nil
}

local function findTickets()
    local tickets = {}
    local gameFolder = workspace:FindFirstChild("Game")
    if gameFolder then
        local ticketsFolder = gameFolder:FindFirstChild("Tickets")
        if ticketsFolder then
            for _, v in ipairs(ticketsFolder:GetChildren()) do
                if v:IsA("BasePart") and v.Transparency < 1 then
                    table.insert(tickets, v)
                end
            end
        end
    end
    local ticketsFolder = workspace:FindFirstChild("Tickets")
    if ticketsFolder then
        for _, v in ipairs(ticketsFolder:GetChildren()) do
            if v:IsA("BasePart") and v.Transparency < 1 then
                table.insert(tickets, v)
            end
        end
    end
    return tickets
end

local function startAutoTicketFarm()
    if getgenv().TicketSystem.AutoConnection then return end
    getgenv().TicketSystem.AutoConnection = RunService.Heartbeat:Connect(function()
        if not getgenv().TicketSystem.AutoTicketFarm then return end
        local char, hrp = player.Character, player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local tickets = findTickets()
        for _, ticket in ipairs(tickets) do
            hrp.CFrame = ticket.CFrame + Vector3.new(0, 2, 0)
            getgenv().TicketSystem.Collected = getgenv().TicketSystem.Collected + 1
            task.wait(0.2)
        end
    end)
end

local function stopAutoTicketFarm()
    if getgenv().TicketSystem.AutoConnection then
        getgenv().TicketSystem.AutoConnection:Disconnect()
        getgenv().TicketSystem.AutoConnection = nil
    end
end

local AutoTicketToggle = AutoTab:Toggle({
    Title = "Auto Ticket Farm",
    Desc = "Otomatis ambil semua tiket",
