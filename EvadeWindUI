local function isPlayerDowned(pl)
    if not pl or not pl.Character then return false end
    local char = pl.Character
    local downed = char:GetAttribute("Downed")
    if downed == true then return true end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health <= 0 then return true end
    return false
end

-- Manual Instant Revive
local function startManualRevive()
    if getgenv().ReviveSystem.Manual.Connection then return end
    getgenv().ReviveSystem.Manual.Connection = RunService.Heartbeat:Connect(function()
        if not getgenv().ReviveSystem.Manual.Enabled then return end
        local myChar, myHRP = player.Character, player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= player and isPlayerDowned(pl) then
                local theirChar, theirHRP = pl.Character, pl.Character and pl.Character:FindFirstChild("HumanoidRootPart")
                if theirHRP then
                    local dist = (myHRP.Position - theirHRP.Position).Magnitude
                    if dist <= 15 then
                        pcall(function() ReplicatedStorage.Events.Character.Interact:FireServer("Revive", true, pl.Name) end)
                        task.wait(0.2)
                    end
                end
            end
        end
    end)
end

-- Auto Instant Revive
local function startAutoRevive()
    if getgenv().ReviveSystem.Auto.Connection then return end
    getgenv().ReviveSystem.Auto.Connection = RunService.Heartbeat:Connect(function()
        if not getgenv().ReviveSystem.Auto.Enabled then return end
        local myChar, myHRP = player.Character, player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        local myPos = myHRP.Position
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= player and isPlayerDowned(pl) then
                local theirChar, theirHRP = pl.Character, pl.Character and pl.Character:FindFirstChild("HumanoidRootPart")
                if theirHRP then
                    local dist = (myPos - theirHRP.Position).Magnitude
                    if dist <= 50 then
                        myHRP.CFrame = theirHRP.CFrame + Vector3.new(0, 3, 0)
                        pcall(function() ReplicatedStorage.Events.Character.Interact:FireServer("Revive", true, pl.Name) end)
                        if getgenv().ReviveSystem.Auto.TeleportBack then
                            task.wait(0.1)
                            myHRP.CFrame = CFrame.new(myPos) + Vector3.new(0, 3, 0)
                        end
                        task.wait(0.3)
                    end
                end
            end
        end
    end)
end

-- Self Revive
local function setupSelfRevive(character)
    if not character then return end
    task.defer(function()
        character:WaitForChild("HumanoidRootPart", 5)
        character:WaitForChild("Humanoid", 5)
        task.spawn(function()
            while character and character.Parent do
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then getgenv().ReviveSystem.Self.LastPosition = hrp.Position end
                task.wait(0.2)
            end
        end)
        character:GetAttributeChangedSignal("Downed"):Connect(function()
            if not getgenv().ReviveSystem.Self.Enabled then return end
            if character:GetAttribute("Downed") ~= true then return end
            local delay = getgenv().ReviveSystem.Self.Mode == "Auto" and getgenv().ReviveSystem.Self.Delay or getgenv().ReviveSystem.Self.InstantDelay
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then getgenv().ReviveSystem.Self.LastPosition = hrp.Position end
            task.wait(delay)
            local startTime = tick()
            repeat
                pcall(function() ReplicatedStorage.Events.Player.ChangePlayerMode:FireServer(true) end)
                task.wait(0.5)
            until character:GetAttribute("Downed") ~= true or tick() - startTime > 2
            local newChar
            repeat newChar = player.Character; task.wait() until newChar and newChar:FindFirstChild("HumanoidRootPart")
            local newHRP = newChar:FindFirstChild("HumanoidRootPart")
            if getgenv().ReviveSystem.Self.LastPosition and newHRP then
                newHRP.CFrame = CFrame.new(getgenv().ReviveSystem.Self.LastPosition)
                task.wait(0.1)
            end
        end)
    end)
end

