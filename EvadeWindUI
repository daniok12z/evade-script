local ConfigManager = Window.ConfigManager
local currentConfigName = "CasaaSettings"
local myConfig = ConfigManager:CreateConfig(currentConfigName)

local configElements = {
    AutoTrimp = AutoTrimpToggle,
    Bhop = BhopToggle,
    NoClip = NoClipToggle,
    AutoCarry = AutoCarryToggle,
    DownedESP = DownedESPToggle,
